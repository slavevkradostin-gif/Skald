            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(0,0,0,0.7);
            color: white;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            padding: 0;
            transition: all 0.2s;
        }
        
        .sticker-delete:hover {
            background: rgba(0,0,0,0.9);
        }
        
        .sticker-card:hover .sticker-delete {
            display: flex;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }
        
        .empty-icon {
            font-size: 64px;
            margin-bottom: 16px;
        }
        
        .empty-state h3 {
            font-size: 18px;
            margin-bottom: 8px;
            color: #666;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.9);
            z-index: 999;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        
        .modal.active {
            display: flex;
        }
        
        .modal-content {
            max-width: 90%;
            max-height: 90%;
            pointer-events: none;
        }
        
        .modal-content img {
            max-width: 100%;
            max-height: 100%;
            border-radius: 8px;
        }
        
        input[type="file"] {
            display: none;
        }
        
        .success-message {
            background: #e8f5e9;
            border: 1px solid #4caf50;
            color: #2e7d32;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }
        
        .success-message.show {
            display: block;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📸 Sticker Tracker</h1>
            <p>Capture and organize your sticker collection</p>
        </div>
        
        <div class="tabs">
            <button class="tab-button active" onclick="switchTab('capture')">Capture</button>
            <button class="tab-button" onclick="switchTab('history')">History</button>
        </div>
        
        <!-- Capture Tab -->
        <div id="capture" class="tab-content active">
            <div class="success-message" id="successMessage">✓ Sticker saved to history!</div>
            
            <div class="upload-area" id="dropZone">
                <div class="upload-icon">📷</div>
                <div class="upload-text">
                    <h3>Upload or Capture a Sticker</h3>
                    <p>Click to upload, take a photo, or drag & drop</p>
                </div>
            </div>
            
            <div class="button-group">
                <button class="primary" onclick="document.getElementById('cameraInput').click()">
                    📸 Take Photo
                </button>
                <button class="primary" onclick="document.getElementById('fileInput').click()">
                    📁 Upload Image
                </button>
            </div>
            
            <div id="previewArea"></div>
        </div>
        
        <!-- History Tab -->
        <div id="history" class="tab-content">
            <div id="historyContent"></div>
        </div>
    </div>
    
    <div class="modal" id="previewModal" onclick="closePreview()">
        <div class="modal-content">
            <img id="previewImage" src="">
        </div>
    </div>
    
    <input type="file" id="fileInput" accept="image/*" onchange="handleFileSelect(event)">
    <input type="file" id="cameraInput" accept="image/*" capture="environment" onchange="handleCameraCapture(event)">
    
    <script>
        const STORAGE_KEY = 'sticker-tracker-history';
        let stickers = [];
        
        // Load stickers on page load
        window.addEventListener('load', () => {
            loadStickers();
            updateHistoryDisplay();
        });
        
        function loadStickers() {
            const saved = localStorage.getItem(STORAGE_KEY);
            stickers = saved ? JSON.parse(saved) : [];
        }
        
        function saveStickers() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(stickers));
        }
        
        function switchTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Show selected tab
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
            
            if (tabName === 'history') {
                updateHistoryDisplay();
            }
        }
        
        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (file) {
                processImage(file);
            }
            event.target.value = '';
        }
        
        function handleCameraCapture(event) {
            const file = event.target.files[0];
            if (file) {
                processImage(file);
            }
            event.target.value = '';
        }
        
        function processImage(file) {
            const reader = new FileReader();
            reader.onload = (e) => {
                const imageData = e.target.result;
                showPreview(imageData);
            };
            reader.readAsDataURL(file);
        }
        
        function showPreview(imageData) {
            const previewArea = document.getElementById('previewArea');
            previewArea.innerHTML = `
                <div class="preview-image">
                    <img src="${imageData}" alt="Preview">
                    <div class="preview-actions">
                        <button class="primary" onclick="saveSticker('${imageData.replace(/'/g, "\\'")}')">
                            ✓ Save to History
                        </button>
                        <button onclick="clearPreview()">Cancel</button>
                    </div>
                </div>
            `;
        }
        
        function clearPreview() {
            document.getElementById('previewArea').innerHTML = '';
        }
        
        function saveSticker(imageData) {
            const now = new Date();
            const sticker = {
                id: Date.now(),
                image: imageData,
                date: now.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
                time: now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })
            };
            
            stickers.unshift(sticker);
            saveStickers();
            clearPreview();
            
            // Show success message
            const msg = document.getElementById('successMessage');
            msg.classList.add('show');
            setTimeout(() => msg.classList.remove('show'), 3000);
        }
        
        function deleteSticker(id) {
            stickers = stickers.filter(s => s.id !== id);
            saveStickers();
            updateHistoryDisplay();
        }
        
        function updateHistoryDisplay() {
            const historyContent = document.getElementById('historyContent');
            
            if (stickers.length === 0) {
                historyContent.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <h3>No stickers yet</h3>
                        <p>Go to Capture tab to add your first sticker!</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div class="sticker-grid">';
            stickers.forEach(sticker => {
                html += `
                    <div class="sticker-card" onclick="openPreview('${sticker.image.replace(/'/g, "\\'")}')">
                        <img src="${sticker.image}" class="sticker-image" alt="Sticker">
                        <button class="sticker-delete" onclick="deleteSticker(${sticker.id}); event.stopPropagation();">×</button>
                        <div class="sticker-info">
                            <div class="sticker-date">${sticker.date}</div>
                            <div>${sticker.time}</div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            historyContent.innerHTML = html;
        }
        
        function openPreview(imageData) {
            document.getElementById('previewImage').src = imageData;
            document.getElementById('previewModal').classList.add('active');
        }
        
        function closePreview() {
            document.getElementById('previewModal').classList.remove('active');
        }
        
        // Drag and drop
        const dropZone = document.getElementById('dropZone');
        
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });
        
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });
        
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                processImage(files[0]);
            }
        });
        
        dropZone.addEventListener('click', () => {
            document.getElementById('fileInput').click();
        });
    </script>
</body>
