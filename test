                        <h3>No stickers yet</h3>
                        <p>Go to Capture tab to add your first sticker!</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div class="sticker-grid">';
            stickers.forEach(sticker => {
                html += `
                    <div class="sticker-card" onclick="openPreview('${sticker.image.replace(/'/g, "\\'")}')">
                        <img src="${sticker.image}" class="sticker-image" alt="Sticker">
                        <button class="sticker-delete" onclick="deleteSticker(${sticker.id}); event.stopPropagation();">×</button>
                        <div class="sticker-info">
                            <div class="sticker-date">${sticker.date}</div>
                            <div>${sticker.time}</div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            historyContent.innerHTML = html;
        }
        
        function openPreview(imageData) {
            document.getElementById('previewImage').src = imageData;
            document.getElementById('previewModal').classList.add('active');
        }
        
        function closePreview() {
            document.getElementById('previewModal').classList.remove('active');
        }
        
        // Drag and drop
        const dropZone = document.getElementById('dropZone');
        
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });
        
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });
        
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                processImage(files[0]);
            }
        });
        
        dropZone.addEventListener('click', () => {
            document.getElementById('fileInput').click();
        });
    </script>
</body>
</html>
